# Value of the buckler_id cookie from streetfighter.com (DevTools → Application → Cookies → www.streetfighter.com → buckler_id)
BUCKLER_ID=your_buckler_id_here

# Your Buckler UID (the number in your profile URL: /6/buckler/profile/<UID>)
CFN_PLAYER_ID=1531841201

# Your M. Bison character name as it appears on Buckler (verify on first run)
CFN_CHARACTER=M. Bison

# Polling interval in seconds (default: 300 = 5 minutes)
POLL_INTERVAL_SECONDS=300

# Google Sheets spreadsheet ID (the long string in the sheet URL)
GOOGLE_SHEET_ID=your_spreadsheet_id_here

# Path to your Google service account credentials JSON
GOOGLE_CREDENTIALS_PATH=credentials.json
